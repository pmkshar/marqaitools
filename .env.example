# Marqai environment variables
# Copy this file to .env.local for local development

# Required for AI features (image gen, content gen, SEO/website analysis, AI tool testing)
# Get your key from the z.ai dashboard
ZAI_API_KEY=

# Optional — Prisma database (SQLite). Defaults to a local file if not set.
DATABASE_URL="file:./db/custom.db"

# Optional — NextAuth (only if you wire up authentication)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
