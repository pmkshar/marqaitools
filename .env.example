# Marqai environment variables
# Copy this file to .env.local for local development

# Required for AI features (image gen, content gen, SEO/website analysis, AI tool testing,
# logo builder, website builder, leads generator).
# Get your key from the z.ai dashboard: https://z.ai
# On Vercel: Project → Settings → Environment Variables → add ZAI_API_KEY.
ZAI_API_KEY=

# Optional — Z.AI API base URL. Defaults to the public Z.AI GLM endpoint.
# Override only if you are using a private Z.AI deployment or proxy.
# If you're in China, try: https://open.bigmodel.cn/api/paas/v4
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Optional — Chat completion model. The Z.AI SDK does NOT auto-fill a
# model; if omitted, the API returns {"error":{"code":"500"}}.
# Common values: glm-4 (default), glm-4-flash (free tier), glm-4-air,
# glm-4-plus, glm-4-long, glm-4.5.
# If your key has no access to glm-4, switch to glm-4-flash first.
ZAI_MODEL=glm-4

# Optional — Image generation model.
# Common values: cogview-3-plus (default, premium), cogview-3-flash (free).
ZAI_IMAGE_MODEL=cogview-3-plus

# Optional — Prisma database (SQLite). Defaults to a local file if not set.
DATABASE_URL="file:./db/custom.db"

# ------------------------------------------------------------------
# NextAuth (real authentication with bcrypt-hashed credentials)
# ------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------------
# Stripe (live subscription billing)
# ------------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get this from https://dashboard.stripe.com/webhooks (create an endpoint
# pointing to https://yourdomain.com/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=

# Recurring Price IDs for each plan (create these in Stripe → Products → Pricing)
# Leave blank to fall back to simulated in-memory upgrades.
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_SCALE=
STRIPE_PRICE_ID_ENTERPRISE=
